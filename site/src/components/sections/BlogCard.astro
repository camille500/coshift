---
import type { Locale } from '../../i18n/utils';
import { useTranslations, getLocalePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { locale, title, description, date, tags, slug } = Astro.props;
const t = useTranslations(locale);

const formattedDate = date.toLocaleDateString(locale === 'nl' ? 'nl-NL' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const href = getLocalePath(`/blog/${slug}`, locale);
---

<a href={href} class="blog-card glass">
  <div class="blog-card-content">
    <div class="blog-card-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-desc">{description}</p>
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.slice(0, 3).map(tag => (
          <span class="blog-tag">{tag}</span>
        ))}
      </div>
    )}
    <span class="blog-card-link">
      {t('blog.readmore')}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </span>
  </div>
</a>

<style>
  .blog-card {
    display: block;
    padding: 28px;
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }
  .blog-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 20%, rgba(0, 212, 170, 0.04), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .blog-card:hover {
    border-color: var(--card-border);
    background: var(--card-bg-hover);
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .blog-card:hover::before { opacity: 1; }
  .blog-card-content { position: relative; }
  .blog-card-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 12px;
    font-weight: 500;
  }
  .blog-card-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  .blog-card-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .blog-tag {
    font-size: 0.7rem;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(0, 212, 170, 0.08);
    color: var(--accent);
    border: 1px solid rgba(0, 212, 170, 0.12);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .blog-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.2s ease;
  }
  .blog-card:hover .blog-card-link {
    gap: 10px;
  }
</style>
