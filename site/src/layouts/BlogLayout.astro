---
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../i18n/utils';
import { useTranslations, getLocalePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  date: Date;
  tags: string[];
  author: string;
}

const { title, description, locale, date, tags, author } = Astro.props;
const t = useTranslations(locale);
const siteURL = 'https://coshift.nl';

const formattedDate = date.toLocaleDateString(locale === 'nl' ? 'nl-NL' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "author": {
    "@type": "Person",
    "name": author,
  },
  "publisher": {
    "@type": "Organization",
    "name": "CoShift",
    "url": siteURL,
  },
  "mainEntityOfPage": new URL(Astro.url.pathname, siteURL).toString(),
  "keywords": tags.join(', '),
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": locale === 'nl' ? siteURL : `${siteURL}/en/`,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": t('blog.label'),
      "item": `${siteURL}${getLocalePath('/blog', locale)}`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
    },
  ],
});
---

<BaseLayout
  title={`${title} | CoShift`}
  description={description}
  locale={locale}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={date.toISOString()} />
    <meta property="article:author" content={author} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <article class="blog-article">
    <div class="blog-article-inner">
      <a href={getLocalePath('/blog', locale)} class="blog-back reveal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        {t('blog.back')}
      </a>

      <header class="blog-header reveal">
        <div class="blog-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="blog-meta-sep">·</span>
          <span>{author}</span>
        </div>
        <h1 class="blog-title">{title}</h1>
        <p class="blog-description">{description}</p>
        {tags.length > 0 && (
          <div class="blog-tags">
            {tags.map(tag => <span class="blog-tag">{tag}</span>)}
          </div>
        )}
      </header>

      <div class="blog-content reveal reveal-delay-1">
        <slot />
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding: 120px 24px 80px;
  }
  .blog-article-inner {
    max-width: 680px;
    margin: 0 auto;
  }
  .blog-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 40px;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .blog-back:hover {
    color: var(--accent);
    gap: 12px;
  }
  .blog-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-glass);
  }
  .blog-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
  }
  .blog-meta-sep { opacity: 0.4; }
  .blog-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .blog-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .blog-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .blog-tag {
    font-size: 0.7rem;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(0, 212, 170, 0.08);
    color: var(--accent);
    border: 1px solid rgba(0, 212, 170, 0.12);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* Blog content prose styling */
  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 48px 0 16px;
    letter-spacing: -0.02em;
  }
  .blog-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 32px 0 12px;
  }
  .blog-content :global(p) {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 20px;
  }
  .blog-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }
  .blog-content :global(em) {
    font-style: italic;
  }
  .blog-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }
  .blog-content :global(a:hover) {
    opacity: 0.8;
  }
  .blog-content :global(ul),
  .blog-content :global(ol) {
    color: var(--text-secondary);
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .blog-content :global(li) {
    line-height: 1.75;
    margin-bottom: 8px;
  }
  .blog-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .blog-content :global(code) {
    font-size: 0.88em;
    padding: 2px 6px;
    background: var(--code-bg);
    border-radius: 4px;
    color: var(--accent);
  }
  .blog-content :global(pre) {
    padding: 20px;
    background: var(--pre-bg);
    border: 1px solid var(--border-glass);
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 20px;
  }
  .blog-content :global(pre code) {
    padding: 0;
    background: none;
  }
  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-glass);
    margin: 40px 0;
  }
  .blog-content :global(mark) {
    background: rgba(0, 212, 170, 0.2);
    color: inherit;
    border-radius: 2px;
    padding: 1px 2px;
  }
  .blog-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 16px 0;
  }
  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
  }
  .blog-content :global(th),
  .blog-content :global(td) {
    border: 1px solid var(--border-glass);
    padding: 10px 14px;
    text-align: left;
    color: var(--text-secondary);
  }
  .blog-content :global(th) {
    background: rgba(255, 255, 255, 0.04);
    font-weight: 600;
    color: var(--text-primary);
  }
  .blog-content :global(sup) { font-size: 0.75em; vertical-align: super; }
  .blog-content :global(sub) { font-size: 0.75em; vertical-align: sub; }

  /* Task lists */
  .blog-content :global(ul[data-type="taskList"]) {
    list-style: none;
    padding-left: 0;
  }
  .blog-content :global(ul[data-type="taskList"] li) {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .blog-content :global(ul[data-type="taskList"] li label input[type="checkbox"]) {
    appearance: none;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 3px;
    background: transparent;
    margin-top: 4px;
    flex-shrink: 0;
  }
  .blog-content :global(ul[data-type="taskList"] li label input[type="checkbox"]:checked) {
    background: var(--accent);
    border-color: var(--accent);
  }

  /* YouTube embeds */
  .blog-content :global(div[data-youtube-video]) {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    margin: 24px 0;
    border-radius: 8px;
  }
  .blog-content :global(div[data-youtube-video] iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 8px;
  }

  /* Lowlight syntax highlighting */
  .blog-content :global(.hljs-comment),
  .blog-content :global(.hljs-quote) { color: #636d83; font-style: italic; }
  .blog-content :global(.hljs-keyword),
  .blog-content :global(.hljs-selector-tag) { color: #c678dd; }
  .blog-content :global(.hljs-number),
  .blog-content :global(.hljs-string),
  .blog-content :global(.hljs-literal),
  .blog-content :global(.hljs-doctag),
  .blog-content :global(.hljs-regexp) { color: var(--accent); }
  .blog-content :global(.hljs-title),
  .blog-content :global(.hljs-section),
  .blog-content :global(.hljs-name) { color: #e5c07b; }
  .blog-content :global(.hljs-attribute),
  .blog-content :global(.hljs-attr),
  .blog-content :global(.hljs-variable) { color: #e5c07b; }
  .blog-content :global(.hljs-built_in) { color: #e06c75; }
  .blog-content :global(.hljs-symbol),
  .blog-content :global(.hljs-bullet),
  .blog-content :global(.hljs-meta),
  .blog-content :global(.hljs-link) { color: #61aeee; }

  @media (max-width: 600px) {
    .blog-article { padding: 100px 20px 60px; }
  }
</style>
