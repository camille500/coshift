---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SignIn } from '@clerk/astro/components';
---

<BaseLayout title="Inloggen | CoShift" description="Log in op CoShift" locale="nl">
  <section class="auth-page">
    <SignIn />
  </section>
</BaseLayout>

<style>
  .auth-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
  }
</style>
