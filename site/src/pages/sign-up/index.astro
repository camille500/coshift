---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SignUp } from '@clerk/astro/components';
---

<BaseLayout title="Registreren | CoShift" description="Maak een CoShift account aan" locale="nl">
  <section class="auth-page">
    <SignUp />
  </section>
</BaseLayout>

<style>
  .auth-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
  }
</style>
